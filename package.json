{
  "name": "@questi0nm4rk/vori",
  "version": "1.0.0",
  "description": "Vault query CLI — search and query Obsidian-style markdown vaults from the terminal",
  "keywords": [
    "obsidian",
    "obsidian-cli",
    "vault",
    "vault-search",
    "vault-query",
    "markdown",
    "markdown-cli",
    "notes",
    "knowledge-base",
    "wikilinks",
    "frontmatter",
    "yaml",
    "second-brain",
    "pkm"
  ],
  "author": "Questi0nM4rk",
  "license": "MIT",
  "type": "module",
  "bin": {
    "vori": "bin/vori.js"
  },
  "files": [
    "bin/vori.js"
  ],
  "scripts": {
    "build": "bun build src/main.ts --compile --outfile bin/vori",
    "build:npm": "bun build src/main.ts --target=bun --outfile bin/vori.js && chmod +x bin/vori.js",
    "test": "bun test",
    "typecheck": "tsgo --noEmit",
    "lint": "biome check src/ __tests__/",
    "lint:fix": "biome check --write src/ __tests__/",
    "prepublishOnly": "bun run typecheck && bun test && bun run build:npm"
  },
  "dependencies": {
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@questi0nm4rk/feats": "^1.0.1",
    "@typescript/native-preview": "latest",
    "bun-types": "latest",
    "typescript": "^6.0.2"
  }
}
